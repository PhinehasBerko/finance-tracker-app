{
  "compilerOptions": {
    "target": "es2018",
    "module": "esNext",
    "lib": [
      "esnext",
      "dom"
    ],
    "allowJs": true,
    "checkJs": false,
    "jsx": "preserve",
    "incremental": true,
    "noEmit": true,
    "strict": true,
    "noImplicitAny": true,
    "strictNullChecks": true,
    "noUnusedLocals": true,
    "noUnusedParameters": true,
    "noImplicitReturns": false,
    "noFallthroughCasesInSwitch": false,
    "baseUrl": ".",
    "paths": {
      "/*": [
        "*"
      ]
    },
    "moduleResolution": "node",
    "resolveJsonModule": true,
    "types": ["node"],
    "esModuleInterop": true,
    "preserveSymlinks": true
  },"include":[
    "**/*.ts",
    "**/*.tsx",
    ".meteor/local/types/packages.d.ts"
  ],
  "exclude": [
    "./packages/**"
  ]
}
// mocha has been removed temporarily for type check